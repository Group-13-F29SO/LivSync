# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# DATABASE_URL="postgresql://postgres:ADAMDUMORTAIN@localhost:5433/Livsync"

# Uncomment and set the DATABASE_URL variable with your actual database credentials to connect your application 
# to the PostgreSQL database.

# Gmail SMTP Configuration for Password Reset Emails
# GMAIL_EMAIL: Your Gmail email address (e.g., your-email@gmail.com)
# GMAIL_APP_PASSWORD: 16-digit app-specific password from Google Account settings
#   - Generate at: https://myaccount.google.com/apppasswords
#   - Select "Mail" and "Windows Computer" (or your device)
#   - Copy the 16-digit password (format: xxxx xxxx xxxx xxxx)
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Make sure to rename this file to .env
